{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Frameward Loop State",
  "type": "object",
  "properties": {
    "active": {
      "type": "boolean"
    },
    "taskType": {
      "type": "string"
    },
    "requiredGates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "completedGates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failedGates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "loopCount": {
      "type": "integer"
    },
    "maxLoops": {
      "type": "integer"
    },
    "mode": {
      "enum": [
        "advisory",
        "balanced",
        "hybrid-strict",
        "strict"
      ]
    },
    "provider": {
      "type": "string"
    },
    "providerMode": {
      "type": "string"
    }
  }
}
